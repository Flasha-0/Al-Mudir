  "shortcuts": [
    {
      "name": "إضافة مهمة",
      "short_name": "مهمة",
      "description": "إضافة مهمة جديدة بسرعة",
      "url": "/?action=new-task",
      "icons": [{ "src": "/icons/shortcut-task.png", "sizes": "96x96" }]
    },
    {
      "name": "ملاحظة جديدة",
      "short_name": "ملاحظة",
      "description": "إنشاء ملاحظة جديدة",
      "url": "/?action=new-note",
      "icons": [{ "src": "/icons/shortcut-note.png", "sizes": "96x96" }]
    },
    {
      "name": "المحادثة",
      "short_name": "شات",
      "description": "فتح المحادثة مع AI",
      "url": "/?tab=chat",
      "icons": [{ "src": "/icons/shortcut-chat.png", "sizes": "96x96" }]
    }
  ],

  "related_applications": [],
  "prefer_related_applications": false,

  "protocol_handlers": [
    {
      "protocol": "web+almudir",
      "url": "/?url=%s"
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text":  "text",
      "url":   "url"
    }
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "handle_links": "preferred",

  "launch_handler": {
    "client_mode": "focus-existing"
  }
}